# Database Configuration
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=urban_gala
MYSQL_USER=urbanuser
MYSQL_PASSWORD=your_secure_db_password_here

# JWT Configuration
APP_JWT_SECRET=your_very_long_and_secure_jwt_secret_here_minimum_256_bits

# External API Keys
VITE_GOOGLE_API_KEY=your_google_maps_api_key_here
HF_TOKEN=your_huggingface_token_here

# Optional: MySQL Configuration File
MYSQL_CONFIG_FILE=my.cnf

# Frontend API routing (dev override; production Docker build uses ARGs instead)
# Relative paths ensure same-origin requests through the Nginx proxy layers.
# These values are baked at build time — never put secrets here.
VITE_API_BASE_URL=/api
VITE_LLM_API_URL=/api/chat

# DEPRECATED: VITE_BACKEND_URL — removed in Phase 2 Plan 02 (use VITE_API_BASE_URL)
# VITE_BACKEND_URL=

# ML Service URLs (local Java-only dev — override application.properties localhost defaults)
# LLM_SERVICE_URL=http://localhost:5001
# BUSYNESS_SERVICE_URL=http://localhost:5002

# Avatar storage (local Java-only dev — relative to JVM working directory)
# APP_AVATARS_DIR=./avatars

# Busyness service model paths (local Python dev — service-scoped; export in busyness shell only)
# MODEL_PATH=BackEnd/busyness-service/models/DNNs
# LSTM_MODEL_PATH=BackEnd/busyness-service/models/LSTMs/Fin.keras